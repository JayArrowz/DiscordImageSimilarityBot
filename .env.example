# ===== Discord =====
DISCORD_TOKEN=your-discord-bot-token-here

# ===== PostgreSQL =====
POSTGRES_USER=imagesim
POSTGRES_PASSWORD=changeme
POSTGRES_DB=imagesim
# Host path where Postgres data files are persisted.
PGDATA_HOST_PATH=./pgdata

# ===== vLLM =====
# HuggingFace model id that vLLM will download and serve.
# This is the single source of truth for which model is used.
VLLM_MODEL=TIGER-Lab/VLM2Vec-Full
# Name vLLM exposes the model under (the .NET app sends this in API requests).
# Keep this in sync with what the bot expects.
VLLM_SERVED_NAME=VLM2Vec-Full
# HF token needed to pull gated models
HUGGING_FACE_HUB_TOKEN=
# Host path where vLLM caches downloaded model weights.
# Persisted on your filesystem so models aren't re-downloaded on rebuild.
HF_CACHE_HOST_PATH=./hf-cache
# vLLM serving knobs
VLLM_MAX_MODEL_LEN=4096
VLLM_TENSOR_PARALLEL_SIZE=1
# Token the bot sends as Bearer to vLLM (set to anything if vLLM has no auth)
VLLM_API_KEY=

# ===== Source images =====
# Absolute (or compose-relative) path on the HOST that gets bind-mounted
# into the container at /app/source_images. The app's SourceImageDir
# config already points at ./source_images which resolves there.
SOURCE_IMAGES_HOST_PATH=./source_images

# ===== AI config consumed by the .NET app =====
# Must match the embedding dimension of VLLM_MODEL.
# VLM2Vec-Full = 3072
AI_VECTOR_DIMENSIONS=3072
AI_ACTIONABLE_THRESHOLD=0.7
AI_BANNABLE=false